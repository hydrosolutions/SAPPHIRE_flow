# OS metadata
.DS_Store

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets
.env
secrets
secrets/

# Downloaded data (never commit)
data/
.data/

# Claude Code — track shared settings.json, ignore machine-local state
# (settings.local.json is also in the global gitignore)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Config overlays — ignore gitignored local operator tweaks, keep .gitkeep tracked
config/overlays/local/*
!config/overlays/local/.gitkeep

# Per-environment performance baseline (Plan 043 §E7) — each env owns its own
tests/fixtures/reference/performance_baseline.json
